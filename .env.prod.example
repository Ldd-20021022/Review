# 三甲医院评级系统 — 生产环境配置
# 复制为 .env.prod 并填入真实值

# ── Database (必须: PostgreSQL) ──
DATABASE_URL=postgresql://emr_user:CHANGE_ME@db:5432/emr_rating
POSTGRES_USER=emr_user
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=emr_rating

# ── Security (必须: 随机生成) ──
# 生成命令: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_TO_RANDOM_64_CHARS
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
SECRET_KEY=CHANGE_ME_TO_ANOTHER_RANDOM_64_CHARS

# ── CORS ──
CORS_ORIGINS=https://your-domain.com

# ── DeepSeek AI ──
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# ── Email (SMTP) ──
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@hospital.com
SMTP_PASS=CHANGE_ME
SMTP_FROM=noreply@hospital.com

# ── App ──
APP_NAME=三甲医院评级系统
DEBUG=false
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# ── Docker ──
DOCKER_ENV=true
